+static BOOL android_relative_mouse_enabled(void)
+{
+    const char *value = getenv( "WINE_ANDROID_RELATIVE_MOUSE" );
+    return value && atoi( value );
+}
+
+static BOOL android_input_debug_enabled(void)
+{
+    const char *value = getenv( "WINE_INPUT_POLL_DEBUG" );
+    return value && atoi( value );
+}
+
+static BOOL android_relative_mouse_active( HWND capture )
+{
+    RECT clip;
+
+    if (!capture || !android_relative_mouse_enabled()) return FALSE;
+    if (!NtUserGetClipCursor( &clip )) return FALSE;
+    return !EqualRect( &clip, &virtual_screen_rect );
+}
