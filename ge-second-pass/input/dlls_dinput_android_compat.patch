+        if (android_dinput_debug_enabled())
+            ERR( "INPUTDBG dinput.android.route iface=%p type=%s raw=%u coop=%#x read_event=%p\n",
+                 &device->IDirectInputDevice8W_iface, android_dinput_type_name( device->instance.dwDevType ),
+                 device->use_raw_input, device->dwCoopLevel, device->read_event );
